# ------------------------------------------------------------------------------
# EXE
# ------------------------------------------------------------------------------

NAME			=	philo

# ------------------------------------------------------------------------------
# DEFINITIONS
# ------------------------------------------------------------------------------

CC				= cc
CFLAGS			= -Wall -Werror -Wextra -I includes -g3
MAKEFLAGS 		+=	--no-print-directory
RM				= rm -rf

# ------------------------------------------------------------------------------
# DIRECTORIES
# ------------------------------------------------------------------------------

SRC_DIR			=	src/
OBJ_DIR			=	obj/

# ------------------------------------------------------------------------------
# FILES
# ------------------------------------------------------------------------------

SRC_FILES		=	main.c
SRCS			=	$(addprefix $(SRC_DIR), $(SRC_FILES))
OBJS			=	$(addprefix $(OBJ_DIR), $(SRC_FILES:.c=.o))

# ------------------------------------------------------------------------------
# RULES
# ------------------------------------------------------------------------------

all :			$(NAME)

$(OBJ_DIR)%.o: $(SRC_DIR)%.c
				@mkdir -p $(dir $@)
				@$(CC) $(CFLAGS) -c $< -o $@
				@echo "Compiling $<"

$(NAME) :		$(OBJS)
				@$(CC) $(CFLAGS) $(OBJS) -o $(NAME)
				@echo "$(NAME) compiled successfuly"

clean :
				@$(RM) $(OBJ_DIR)
				@echo "$(NAME) cleaned successfuly"

fclean :		clean
				@$(RM) $(NAME)

re :			fclean all

.PHONY:			all clean fclean re